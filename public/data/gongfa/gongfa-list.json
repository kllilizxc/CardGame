{
  "gongfa": [
    {
      "id": "gongfa.return_sword_end_turn",
      "name": "引剑回收",
      "schema": {
        "event": {
          "type": "TurnEnd",
          "side": "Ally"
        },
        "conditions": [
          {
            "type": "ArtifactUsedThisTurn",
            "weaponType": "剑",
            "minimum": 1
          }
        ],
        "actions": [
          {
            "type": "RecoverCardFromDiscard",
            "filter": {
              "kind": ["artifact"],
              "weaponTypesAnyOf": ["剑"],
              "maxStar": "card.star + 2",
              "amount": 1
            },
            "destination": "Hand",
            "amount": 1
          }
        ]
      }
    },
    {
      "id": "gongfa.search_sword_on_summon",
      "name": "检索剑器",
      "schema": {
        "event": {
          "type": "OnSummon",
          "side": "Ally"
        },
        "actions": [
          {
            "type": "SearchCardFromDeck",
            "filter": {
              "kind": ["artifact"],
              "weaponTypesAnyOf": ["剑"],
              "maxStar": "card.star + 1",
              "amount": 1
            },
            "destination": "Hand",
            "amount": 1
          }
        ]
      }
    },
    {
      "id": "gongfa.sword_control_basic",
      "name": "控剑术·基础",
      "schema": {
        "event": {
          "type": "OnEquipArtifact",
          "side": "Ally"
        },
        "conditions": [
          {
            "type": "ArtifactEquipped",
            "weaponType": "剑",
            "maxStar": "card.star + 1"
          }
        ],
        "actions": [
          {
            "type": "ImmediateAttack",
            "target": "singleEnemy",
            "damageMultiplier": 1.0
          }
        ]
      }
    },
    {
      "id": "gongfa.sword_recall",
      "name": "剑意呼唤",
      "schema": {
        "event": {
          "type": "OnSummon",
          "side": "Ally"
        },
        "actions": [
          {
            "type": "RecoverCardFromDiscard",
            "filter": {
              "kind": ["artifact"],
              "weaponTypesAnyOf": ["剑"],
              "amount": 1
            },
            "destination": "Hand",
            "amount": 1
          }
        ]
      }
    },
    {
      "id": "gongfa.sword_control_shield",
      "name": "控剑术·盾",
      "schema": {
        "event": {
          "type": "OnEquipArtifact",
          "side": "Ally"
        },
        "conditions": [
          {
            "type": "ArtifactEquipped",
            "weaponType": "剑",
            "maxStar": "card.star + 1"
          }
        ],
        "actions": [
          {
            "type": "GainArmor",
            "target": "self",
            "value": "artifact.star * 2"
          }
        ]
      }
    },
    {
      "id": "gongfa.search_swords_to_discard",
      "name": "剑器检索·弃牌",
      "schema": {
        "event": {
          "type": "OnSummon",
          "side": "Ally"
        },
        "actions": [
          {
            "type": "SearchCardFromDeck",
            "filter": {
              "kind": ["artifact"],
              "weaponTypesAnyOf": ["剑"],
              "maxStar": "card.star + 1"
            },
            "destination": "DiscardPile",
            "amount": 1
          }
        ]
      }
    },
    {
      "id": "gongfa.sword_heart_slash_aoe",
      "name": "控剑术·剑心斩（AOE）初级",
      "schema": {
        "event": {
          "type": "OnEquipArtifact",
          "side": "Ally"
        },
        "conditions": [
          {
            "type": "ArtifactEquipped",
            "weaponType": "剑",
            "maxStar": "card.star + 1"
          }
        ],
        "actions": [
          {
            "type": "ImmediateAttack",
            "target": "allEnemies",
            "damageMultiplier": 0.5
          }
        ]
      }
    },
    {
      "id": "gongfa.draw_filter_sword_cultivator",
      "name": "剑修筛选",
      "schema": {
        "event": {
          "type": "OnSummon",
          "side": "Ally"
        },
        "actions": [
          {
            "type": "DrawAndFilter",
            "amount": 2,
            "filter": {
              "labelsAnyOf": ["剑修"]
            },
            "matchDestination": "Hand",
            "nonMatchDestination": "DiscardPile"
          }
        ]
      }
    },
    {
      "id": "gongfa.sword_intent_burst_aoe",
      "name": "控剑术·剑意爆发（AOE）",
      "schema": {
        "event": {
          "type": "OnEquipArtifact",
          "side": "Ally"
        },
        "conditions": [
          {
            "type": "ArtifactEquipped",
            "weaponType": "剑",
            "maxStar": "card.star + 1"
          }
        ],
        "actions": [
          {
            "type": "ImmediateAttack",
            "target": "allEnemies",
            "damageMultiplier": 0.5
          }
        ]
      }
    }
  ]
}
